{
  "manifest_version": 3,
  "name": "YouTube Topic Blocker",
  "version": "0.1.0",
  "description": "Hide YouTube videos that match blocked topics. Titles stay hidden until LLM safety checks finish.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://api.openai.com/*"
  ],
  "icons": {
    "128": "assets/icons/128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "YouTube Topic Blocker",
    "default_icon": {
      "128": "assets/icons/128.png"
    },
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html"
}